// Architecture diagram — self-hosted stack network topology
// Render:  dot -Tsvg architecture.dot -o architecture-diagram.svg
//          dot -Tpng -Gdpi=160 architecture.dot -o architecture-diagram.png
// Redaction-safe: service + network names only — no domain, IP, or secrets.

digraph stack {
  rankdir=TB;
  compound=true;
  bgcolor="white";
  pad=0.4;
  nodesep=0.38;
  ranksep=0.7;
  fontname="Helvetica";
  labelloc="t";
  label=<<b>Self-Hosted Stack — Network Topology</b><br/><font point-size="10" color="#64748b">Two Docker networks. The autonomous AI agent is isolated — no route to any data store.</font><br/> >;

  node [fontname="Helvetica", shape=box, style="rounded,filled", fontsize=11,
        color="#475569", fillcolor="#ffffff", penwidth=1.3, margin="0.20,0.11"];
  edge [fontname="Helvetica", fontsize=9, color="#64748b"];

  internet [label="Internet", shape=ellipse, fillcolor="#e2e8f0", color="#94a3b8"];
  caddy    [label=<<b>Caddy</b><br/>reverse proxy · auto-HTTPS>, fillcolor="#dbeafe", color="#2563eb"];

  internet -> caddy [label="80 / 443 · HTTPS", fontcolor="#334155", penwidth=1.5];

  subgraph cluster_app {
    label=<<b>openwebui_default</b>   ·   main app network>;
    labeljust="l";
    style="rounded,filled";
    color="#cbd5e1";
    fillcolor="#f8fafc";
    fontsize=12;
    fontcolor="#334155";
    margin=18;

    tinyauth   [label=<<b>Tinyauth</b><br/>SSO · forward-auth>, fillcolor="#fef3c7", color="#d97706"];
    owui       [label=<<b>Open WebUI</b><br/>AI chat>, fillcolor="#e0e7ff", color="#4f46e5"];
    searxng    [label=<<b>SearXNG</b><br/>metasearch>, fillcolor="#e0e7ff", color="#4f46e5"];
    actual     [label="Actual Budget"];
    freshrss   [label="FreshRSS"];
    memos      [label="Memos"];
    linkwarden [label="Linkwarden"];
    ittools    [label="IT-Tools"];
    homepage   [label="Homepage"];
    kuma       [label="Uptime Kuma"];
    postgres   [label=<<b>PostgreSQL</b><br/>data store>, shape=cylinder, fillcolor="#fee2e2", color="#dc2626"];

    linkwarden -> postgres [label="db", fontsize=8];
  }

  subgraph cluster_hermes {
    label="";
    style="rounded,filled,dashed";
    color="#f87171";
    fillcolor="#fff1f2";
    margin=18;

    hermes [label=<<b>Hermes</b><br/>autonomous AI agent>, fillcolor="#ffedd5", color="#ea580c"];
    hermes_label [shape=plaintext, fontsize=12,
                  label=<<font color="#b91c1c"><b>hermes-net</b></font>   ·   <font color="#b91c1c">isolated AI-agent network</font>>];
    hermes -> hermes_label [style=invis];
    { rank=same; hermes; hermes_label; }
  }

  // Caddy fronts the whole app network (single clean edge to the cluster border)
  caddy -> tinyauth [lhead=cluster_app, label="routes all\nsubdomains", fontcolor="#334155", penwidth=1.5];

  // Legitimate bridges into the isolated network (the only two services the agent needs)
  owui    -> hermes [dir=both, color="#16a34a", fontcolor="#15803d", penwidth=1.9, label="bridge"];
  searxng -> hermes [dir=both, color="#16a34a", fontcolor="#15803d", penwidth=1.9, label="bridge"];

  // The deliberate non-route — the security headline of the whole design
  hermes:w -> postgres:e [style=dashed, color="#dc2626", fontcolor="#b91c1c", penwidth=1.7,
                      constraint=false, label="✗  no route\n(default-closed)"];
}
